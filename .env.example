# ============================================
# AI Billing Engine - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- Database ----
# PostgreSQL connection string (matches docker-compose defaults)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_billing

# ---- OpenRouter ----
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ---- Stripe ----
# Get your test-mode secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-key-here

# The event name for the Stripe Billing Meter (must match the meter you create in Stripe)
# The app will auto-create this meter on first startup if it doesn't exist
STRIPE_METER_EVENT_NAME=ai_tokens_used

# ---- App ----
# Port the Express server listens on (inside the container)
PORT=3000

# Log level: debug, info, warn, error
LOG_LEVEL=info
